// Prisma Schema - 鹏哥个人品牌网站数据库模型

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  password      String
  deviceId      String?   @unique // 绑定设备ID
  name          String?
  avatar        String?
  points        Int       @default(100) // 注册送100积分
  role          String    @default("user") // user | admin
  inviteCode    String    @unique @default(cuid()) // 邀请码
  invitedBy     String?   // 邀请人ID
  subscriptionExpiresAt DateTime? // 订阅到期时间（年卡激活后设置）
  currentToken  String?   // 当前有效的登录 token（单设备限制）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  pointTransactions   PointTransaction[]
  toolUsages          ToolUsage[]
  motionControlTasks  MotionControlTask[]
  // 关联


  @@index([email])
  @@index([phone])
  @@index([inviteCode])
  @@index([deviceId]) // Index for device lookups
}

// AI工具模型
model Tool {
  id            String      @id @default(cuid())
  name          String
  nameEn        String?
  description   String
  descriptionEn String?
  icon          String?
  points        Int         @default(5) // 使用消耗积分
  url           String?     // 工具跳转链接
  isExternal    Boolean     @default(false) // 是否外部链接（需要带token跳转）
  downloadUrl   String?     // 下载地址（百度网盘等）
  tutorialUrl     String?     // 教程视频链接
  tutorialContent String?     // 教程正文（Markdown）
  category      String      @default("doctor_ip") // doctor_ip | director | designer | general
  industry      String      @default("general")   // general | medical_beauty
  status        String      @default("active") // active | inactive | coming
  sortOrder     Int         @default(0)
  visible       Boolean     @default(true)
  apiUrl        String?     // API调用地址
  apiKey        String?     // API密钥（仅服务端使用）
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // 关联
  usages             ToolUsage[]
  activationCodes    ActivationCode[]
  motionControlTasks MotionControlTask[]

  @@index([status])
}

// 激活码模型
model ActivationCode {
  id          String    @id @default(cuid())
  code        String    @unique // 激活码
  type        String    @default("annual") // annual | recharge
  points      Int       @default(0) // 包含的积分（recharge 类型使用）
  toolId      String?   // 对应工具（保留字段，兼容旧数据）
  userId      String?   // 分配给的用户
  deviceId    String?   // 绑定的设备ID（客户端激活使用）
  maxUses     Int       @default(1) // 最大可激活设备数（默认1台）
  usedCount   Int       @default(0) // 已激活设备数
  usedDevices String?   // 已激活的设备ID列表，JSON数组格式 如 ["deviceA","deviceB"]
  status      String    @default("unused") // unused | used | assigned | expired
  note        String?   // 备注
  createdAt   DateTime  @default(now())
  usedAt      DateTime? // 最后一次使用时间

  // 关联
  tool      Tool?     @relation(fields: [toolId], references: [id]) // Made optional

  @@index([code])
  @@index([toolId])
  @@index([userId])
  @@index([status])
}

// 工具使用记录
model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  points    Int      // 消耗的积分
  createdAt DateTime @default(now())

  // 关联
  user      User     @relation(fields: [userId], references: [id])
  tool      Tool     @relation(fields: [toolId], references: [id])

  @@index([userId])
  @@index([toolId])
}

// 积分交易记录
model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // 正数为增加，负数为扣除
  type        String   // register | invite | invited | use_tool | recharge | trial | refund | admin_adjust
  description String?
  relatedId   String?  // 关联的工具ID或用户ID
  createdAt   DateTime @default(now())

  // 关联
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([relatedId])
}

// 动作复刻任务（第三方 Motion Control API）
model MotionControlTask {
  id                   String   @id @default(cuid())
  userId               String
  toolId               String?

  externalTaskId       String   @unique // 我方生成，用于幂等/追踪
  providerTaskId       String?  @unique // 第三方生成的 task_id

  status               String
  statusMsg            String?
  requestId            String?

  modelName            String
  mode                 String
  characterOrientation String
  keepOriginalSound    String
  prompt               String?
  watermarkEnabled     Boolean  @default(false)

  imageUrl             String
  videoUrl             String

  resultUrl            String?
  watermarkUrl         String?
  durationSeconds      Float?
  finalUnitDeduction   String?

  // 计费：10积分/秒（提交时预扣上限，成功后按实际时长结算，多退少补）
  maxPoints            Int
  finalPoints          Int?
  refundedPoints       Int?
  finalizedAt          DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // 关联
  user                 User     @relation(fields: [userId], references: [id])
  tool                 Tool?    @relation(fields: [toolId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([providerTaskId])
}

// 客服 FAQ
model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 客服会话
model ChatSession {
  id        String        @id @default(cuid())
  sessionId String        @unique
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

// 客服消息
model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // user | assistant
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}
