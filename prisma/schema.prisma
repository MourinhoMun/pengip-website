// Prisma Schema - 鹏哥个人品牌网站数据库模型

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// 用户模型
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  password      String
  deviceId      String?   @unique // 绑定设备ID
  name          String?
  avatar        String?
  points        Int       @default(100) // 注册送100积分
  role          String    @default("user") // user | admin
  inviteCode    String    @unique @default(cuid()) // 邀请码
  invitedBy     String?   // 邀请人ID
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  pointTransactions PointTransaction[]
  toolUsages        ToolUsage[]
  // 关联


  @@index([email])
  @@index([phone])
  @@index([inviteCode])
  @@index([deviceId]) // Index for device lookups
}

// AI工具模型
model Tool {
  id            String      @id @default(cuid())
  name          String
  nameEn        String?
  description   String
  descriptionEn String?
  icon          String?
  points        Int         @default(5) // 使用消耗积分
  url           String?     // 工具跳转链接
  downloadUrl   String?     // 下载地址（百度网盘等）
  tutorialUrl   String?     // 教程视频链接
  status        String      @default("active") // active | inactive | coming
  sortOrder     Int         @default(0)
  visible       Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // 关联
  usages          ToolUsage[]
  activationCodes ActivationCode[]

  @@index([status])
}

// 激活码模型
model ActivationCode {
  id          String    @id @default(cuid())
  code        String    @unique // 激活码
  type        String    @default("tool_activation") // tool_activation | license | recharge
  points      Int       @default(0) // 包含的积分
  toolId      String?   // 对应工具 (Optional for license/recharge codes)
  userId      String?   // 分配给的用户
  deviceId    String?   // 绑定的设备ID（兼容旧逻辑）
  maxUses     Int       @default(3) // 最大可激活设备数
  usedCount   Int       @default(0) // 已激活设备数
  usedDevices String?   // 已激活的设备ID列表，JSON数组格式 如 ["deviceA","deviceB"]
  status      String    @default("unused") // unused | active | used | assigned | expired
  note        String?   // 备注
  createdAt   DateTime  @default(now())
  usedAt      DateTime? // 最后一次使用时间

  // 关联
  tool      Tool?     @relation(fields: [toolId], references: [id]) // Made optional

  @@index([code])
  @@index([toolId])
  @@index([userId])
  @@index([status])
}

// 工具使用记录
model ToolUsage {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  points    Int      // 消耗的积分
  createdAt DateTime @default(now())

  // 关联
  user      User     @relation(fields: [userId], references: [id])
  tool      Tool     @relation(fields: [toolId], references: [id])

  @@index([userId])
  @@index([toolId])
}

// 积分交易记录
model PointTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // 正数为增加，负数为扣除
  type        String   // register | invite | invited | use_tool | recharge | admin_adjust
  description String?
  relatedId   String?  // 关联的工具ID或用户ID
  createdAt   DateTime @default(now())

  // 关联
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}
